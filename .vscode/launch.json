  "configurations": [
    {
      "name": "debug actions run",
      "type": "bun",
      "request": "launch",
      "program": "${workspaceFolder}/src/cmd",
      "args": ["run", "-W", "test/workflows/basic.yml", "-v"],
      "env": {}
    },
    {
      "name": "debug a file",
      "type": "node",
      "request": "launch",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "tsx",
      "program": "${file}",
      // "preLaunchTask": "tsc:build - tsconfig.json",
      "env": {},
      "autoAttachChildProcesses": true
    }
  ]
}
