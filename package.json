{
  "name": "actions",
  "version": "1.1.0",
  "description": "Impl Github Actions & Runner(Run GitHub actions locally) using typescript",
  "keywords": [
    "actions",
    "actions-runner",
    "github-actions",
    "runner"
  ],
  "license": "MIT",
  "author": "sobird",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sobird/actions.git"
  },
  "bin": {
    "actions": "dist/index.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "index.js",
  "scripts": {
    "actions:test": "bun src/cmd run -W test/workflows/basic.yml -v",
    "build": "next build",
    "build:actions": "bun scripts/build.ts",
    "build:buf": "buf generate https://gitea.com/sobird/actions-proto-def.git",
    "dev": "next dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "postinstall": "echo \"postinstall\"",
    "prepare": "husky",
    "prepublishOnly": "npm run build:actions",
    "start": "next start",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/expressions": "^0.3.56",
    "@actions/hashfiles": "workspace:*",
    "@actions/workflow-parser": "^0.3.56",
    "@bufbuild/protobuf": "^2.12.0",
    "@clack/prompts": "^1.4.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-next": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/webhooks": "^14.2.0",
    "async-mutex": "^0.5.0",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cron": "^4.4.0",
    "dockerode": "^5.0.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "git-url-parse": "^16.1.0",
    "ignore": "^7.0.5",
    "ip": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "log4js": "^6.9.1",
    "minimatch": "^10.2.5",
    "next": "^16.2.6",
    "prompts": "^2.4.2",
    "rc": "^1.2.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "retry": "^0.13.1",
    "sequelize": "^6.37.8",
    "shell-quote": "^1.8.3",
    "simple-git": "^3.36.0",
    "sqlite3": "^6.0.1",
    "ssh2": "^1.17.0",
    "tar": "^7.5.15",
    "yaml": "^2.8.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/body-parser": "^1.19.6",
    "@types/bun": "^1.3.13",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/ip": "^1.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/prompts": "^2.4.9",
    "@types/rc": "^1.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/retry": "^0.12.5",
    "@types/shell-quote": "^1.7.5",
    "@types/supertest": "^7.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-notifier": "^10.0.1",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.63.0",
    "oxlint-tsgolint": "^0.22.1",
    "postcss": "^8.5.14",
    "smee-client": "^5.0.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "ts-protoc-gen": "^0.15.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": "oxlint --fix"
  },
  "trustedDependencies": [
    "@bufbuild/buf",
    "esbuild",
    "protobufjs",
    "sqlite3",
    "cpu-features",
    "sharp",
    "ssh2"
  ]
}
