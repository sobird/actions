// https://oxc.rs/docs/guide/usage/linter/config.html
{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "error",
  },
  "rules": {
    "unicorn/prefer-node-protocol": "error",
  },
  "env": {
    "builtin": true,
  },
  "ignorePatterns": ["node_modules/", "dist/"],
}
